MAX_UPLOAD_SIZE_MB=100
SEARCH_TIMEOUT_SEC=15
SEARCH_RATE_DELAY_MIN=0.5
SEARCH_RATE_DELAY_MAX=1.5
DEFAULT_MODE=parallel
UPLOAD_DIR=/tmp/tabmonster/uploads

# 選填：加強歌曲辨識用（歌手/歌名/語言/曲風），沒填就完全不影響其他功能，
# 純 regex 版本一樣能跑。免費申請：https://aistudio.google.com/apikey
GEMINI_API_KEY=待填入你自己的免費_Gemini_API_Key
GEMINI_MODEL=gemini-2.0-flash
